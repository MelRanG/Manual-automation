# 데이터베이스
# 로컬 개발: localhost:5600 / docker-compose: db:5432 (compose가 자동 덮어씀)
DATABASE_URL=postgresql+asyncpg://docops:docops_dev@localhost:5600/docops

# LLM 프로바이더: bedrock | anthropic | openai | mock
LLM_PROVIDER=mock

# AWS Bedrock (LLM_PROVIDER=bedrock 일 때)
# 방식 1 (권장): 사내 LiteLLM 게이트웨이 — BEDROCK_API_KEY는 get-gateway-token.sh 실행 결과값
BEDROCK_GATEWAY_URL=https://awsllmgw.hist.co.kr/bedrock
BEDROCK_API_KEY=
# 방식 2: SSO 프로필 (BEDROCK_GATEWAY_URL 비워두면 사용)
AWS_PROFILE=claude-code
# 방식 3: 액세스 키 직접 입력 (AWS_PROFILE도 비워두면 사용 — 키 유출 주의)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Anthropic 직접 (LLM_PROVIDER=anthropic 일 때)
ANTHROPIC_API_KEY=

# OpenAI (LLM_PROVIDER=openai 일 때)
OPENAI_API_KEY=

# 임베딩: mock | openai
EMBEDDING_MODEL=mock

# Jira 웹훅 URL (SR 제출 시 Jira로 전송)
JIRA_WEBHOOK_URL=

# 보안 키 (프로덕션에서 반드시 변경)
SECRET_KEY=change-me-in-production
